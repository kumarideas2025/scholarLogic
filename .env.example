# ScholarLogic Backend Environment Variables

# Server Configuration
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:3000
COOKIE_SECRET=your_super_secure_cookie_secret_key_here_change_in_production
CORS_ORIGIN=http://localhost:3000

# Authentication & JWT
JWT_ACCESS_SECRET=your_super_secure_access_token_secret_key_here_change_in_production
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_SECRET=your_super_secure_refresh_token_secret_key_here_change_in_production
JWT_REFRESH_EXPIRE=7d

# Database Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/scholarlogic?retryWrites=true&w=majority

# Password Hashing
BCRYPT_ROUNDS=12

# Email Configuration (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM=noreply@scholarlogic.com

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security Headers
ENABLEHelmet=true

# Logging
LOG_LEVEL=info
LOG_FILE=logs/combined.log
ERROR_LOG_FILE=logs/error.log

# AI Integration (Optional)
GEMINI_API_KEY=your_gemini_api_key_here

# Backup Admin Credentials (Change in Production)
ADMIN_EMAIL=admin@scholarlogic.com
ADMIN_PASSWORD=ChangeThisAdminPass123!

# Session Configuration
SESSION_TIMEOUT=86400
SESSION_SECRET=your_session_secret_key_here_change_in_production

# File Upload Limits
MAX_FILE_SIZE_MB=10
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,webp,svg

# Email Verification
EMAIL_VERIFICATION_EXPIRY=24h
PASSWORD_RESET_EXPIRY=1h

# Analytics (Optional)
ANALYTICS_API_KEY=
ANALYTICS_PROJECT_ID=